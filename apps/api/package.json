    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@adscrush/typescript-config": "workspace:*",
    "@types/bun": "^1.3.11",
    "dotenv": "^17.2.2",
    "dotenv-expand": "^12.0.3",
    "typescript": "^5.9.3"
