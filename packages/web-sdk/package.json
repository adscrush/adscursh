{
  "name": "@adscrush/web-sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "deploy:pages": "pnpm build && node ./scripts/deploy-pages.mjs"
  },
  "devDependencies": {
    "@adscrush/typescript-config": "workspace:*",
    "@types/node": "^25.1.0",
    "tsup": "^8.3.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}