{
  "name": "@adscrush/shared",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./constants": "./src/constants/index.ts",
    "./constants/roles": "./src/constants/roles.ts",
    "./validators/*": "./src/validators/*.ts",
    "./types": "./src/types/index.ts",
    "./utils/*": "./src/utils/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@adscrush/eslint-config": "workspace:*",
    "@adscrush/typescript-config": "workspace:*",
    "@types/node": "^25.1.0",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
