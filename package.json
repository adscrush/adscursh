{
  "name": "adscrush",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:push": "turbo db:push --filter=@adscrush/db",
    "db:generate": "turbo db:generate --filter=@adscrush/db",
    "db:migrate": "turbo db:migrate --filter=@adscrush/db",
    "db:studio": "pnpm --filter @adscrush/db db:studio",
    "deploy:web-sdk:pages": "pnpm --filter @adscrush/web-sdk deploy:pages"
  },
  "devDependencies": {
    "@adscrush/eslint-config": "workspace:*",
    "@adscrush/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
